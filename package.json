{
  "name": "vscode-kospi",
  "displayName": "vscode kospi",
  "description": "VS Code 사이드바에서 주가와 지수를 텍스트로 보여주는 확장입니다.",
  "version": "0.0.4",
  "publisher": "taehyunkim3",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.114.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:runtimeFeedView",
    "onView:runtimeNewsView",
    "onCommand:runtimeFeed.refresh",
    "onCommand:runtimeFeed.refreshNews",
    "onCommand:runtimeFeed.addWatchSymbol",
    "onCommand:runtimeFeed.removeWatchSymbol",
    "onCommand:runtimeFeed.pickNewsSymbol",
    "onCommand:runtimeFeed.selectSymbol"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "keywords": [
    "vscode",
    "sidebar",
    "monitor",
    "market",
    "fx",
    "stock",
    "kospi",
    "kosdaq",
    "nasdaq",
    "dowjones",
    "s&p500"
  ],
  "author": "",
  "license": "ISC",
  "icon": "media/icon.png",
  "homepage": "https://github.com/taehyunkim3/vscode-kospi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/taehyunkim3/vscode-kospi.git"
  },
  "bugs": {
    "url": "https://github.com/taehyunkim3/vscode-kospi/issues"
  },
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "SUPPORT.md",
    "media",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodeKospi",
          "title": "vscode kospi",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vscodeKospi": [
        {
          "id": "runtimeFeedView",
          "name": "Market Quotes"
        },
        {
          "id": "runtimeNewsView",
          "name": "Top News"
        }
      ]
    },
    "commands": [
      {
        "command": "runtimeFeed.refresh",
        "title": "Refresh vscode stock",
        "icon": "$(refresh)"
      },
      {
        "command": "runtimeFeed.addWatchSymbol",
        "title": "Register Relay Target",
        "icon": "$(add)"
      },
      {
        "command": "runtimeFeed.refreshNews",
        "title": "Refresh News",
        "icon": "$(radio-tower)"
      },
      {
        "command": "runtimeFeed.pickNewsSymbol",
        "title": "Select News Symbol",
        "icon": "$(list-selection)"
      },
      {
        "command": "runtimeFeed.removeWatchSymbol",
        "title": "Remove Relay Target",
        "icon": "$(trash)"
      },
      {
        "command": "runtimeFeed.selectSymbol",
        "title": "Select News Target"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "runtimeFeed.refresh",
          "when": "view == runtimeFeedView",
          "group": "navigation@1"
        },
        {
          "command": "runtimeFeed.addWatchSymbol",
          "when": "view == runtimeFeedView",
          "group": "navigation@2"
        },
        {
          "command": "runtimeFeed.removeWatchSymbol",
          "when": "view == runtimeFeedView",
          "group": "navigation@4"
        },
        {
          "command": "runtimeFeed.refreshNews",
          "when": "view == runtimeNewsView",
          "group": "navigation@1"
        },
        {
          "command": "runtimeFeed.pickNewsSymbol",
          "when": "view == runtimeNewsView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "runtimeFeed.removeWatchSymbol",
          "when": "view == runtimeFeedView && viewItem == watchTarget",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "vscode stock",
      "properties": {
        "runtimeFeed.watchlist": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Watch targets. Examples: `AAPL`, `MSFT`, `005930.KS`, `Naver=035420.KS`, `Kakao=035720.KQ`."
        },
        "runtimeFeed.displayMode": {
          "type": "string",
          "default": "stealth",
          "enum": [
            "stealth",
            "explicit"
          ],
          "markdownDescription": "Controls whether labels look like a generic operations panel (`stealth`) or show direct market names (`explicit`)."
        },
        "runtimeFeed.autoRefreshSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "markdownDescription": "Automatic refresh interval in seconds. `0` disables polling."
        },
        "runtimeFeed.requestTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 2000,
          "markdownDescription": "HTTP timeout for the upstream quote request."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.114.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^6.0.2"
  }
}
