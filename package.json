{
  "name": "vscode-kospi",
  "displayName": "KOSPI Stock Monitor",
  "description": "KOSPI, KOSDAQ, NASDAQ, S&P 500, Dow, USD/KRW 환율과 관심 종목 뉴스/시세를 VS Code/Cursor 사이드바에서 보여주는 주식 모니터 확장입니다.",
  "version": "0.0.7",
  "publisher": "taehyunkim3",
  "pricing": "Free",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onView:runtimeFeedView",
    "onView:runtimeNewsView",
    "onCommand:runtimeFeed.refresh",
    "onCommand:runtimeFeed.refreshNews",
    "onCommand:runtimeFeed.addWatchSymbol",
    "onCommand:runtimeFeed.removeWatchSymbol",
    "onCommand:runtimeFeed.pickNewsSymbol",
    "onCommand:runtimeFeed.selectSymbol"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "keywords": [
    "cursor",
    "cursor-extension",
    "vscode",
    "vscode-extension",
    "sidebar",
    "monitor",
    "stock",
    "stocks",
    "stock-market",
    "ticker",
    "quotes",
    "watchlist",
    "finance",
    "market",
    "financial-market",
    "market-news",
    "news",
    "yahoo-finance",
    "kospi",
    "kosdaq",
    "krx",
    "korea-stock",
    "korean-stock",
    "korean-market",
    "코스피",
    "코스닥",
    "국내주식",
    "한국주식",
    "주식",
    "증시",
    "시세",
    "관심종목",
    "환율",
    "달러환율",
    "fx",
    "forex",
    "exchange-rate",
    "usd-krw",
    "jpy-krw",
    "nasdaq",
    "나스닥",
    "dowjones",
    "dow",
    "s&p500",
    "sp500",
    "us-stock",
    "미국주식"
  ],
  "author": "",
  "license": "ISC",
  "icon": "media/icon.png",
  "homepage": "https://github.com/taehyunkim3/vscode-kospi#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/taehyunkim3/vscode-kospi.git"
  },
  "bugs": {
    "url": "https://github.com/taehyunkim3/vscode-kospi/issues"
  },
  "galleryBanner": {
    "color": "#1f1f1f",
    "theme": "dark"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "SUPPORT.md",
    "media",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodeKospi",
          "title": "KOSPI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vscodeKospi": [
        {
          "id": "runtimeFeedView",
          "name": "Market Quotes"
        },
        {
          "id": "runtimeNewsView",
          "name": "Top News"
        }
      ]
    },
    "commands": [
      {
        "command": "runtimeFeed.refresh",
        "title": "Refresh Market Quotes",
        "icon": "$(refresh)"
      },
      {
        "command": "runtimeFeed.addWatchSymbol",
        "title": "Add Watch Symbol",
        "icon": "$(add)"
      },
      {
        "command": "runtimeFeed.refreshNews",
        "title": "Refresh News",
        "icon": "$(radio-tower)"
      },
      {
        "command": "runtimeFeed.pickNewsSymbol",
        "title": "Select News Symbol",
        "icon": "$(list-selection)"
      },
      {
        "command": "runtimeFeed.removeWatchSymbol",
        "title": "Remove Watch Symbol",
        "icon": "$(trash)"
      },
      {
        "command": "runtimeFeed.selectSymbol",
        "title": "Select News Target"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "runtimeFeed.refresh",
          "when": "view == runtimeFeedView",
          "group": "navigation@1"
        },
        {
          "command": "runtimeFeed.addWatchSymbol",
          "when": "view == runtimeFeedView",
          "group": "navigation@2"
        },
        {
          "command": "runtimeFeed.removeWatchSymbol",
          "when": "view == runtimeFeedView",
          "group": "navigation@4"
        },
        {
          "command": "runtimeFeed.refreshNews",
          "when": "view == runtimeNewsView",
          "group": "navigation@1"
        },
        {
          "command": "runtimeFeed.pickNewsSymbol",
          "when": "view == runtimeNewsView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "runtimeFeed.removeWatchSymbol",
          "when": "view == runtimeFeedView && viewItem == watchTarget",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "KOSPI Stock Monitor",
      "properties": {
        "runtimeFeed.watchlist": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Watch targets. Examples: `AAPL`, `MSFT`, `005930.KS`, `Naver=035420.KS`, `Kakao=035720.KQ`."
        },
        "runtimeFeed.displayMode": {
          "type": "string",
          "default": "explicit",
          "enum": [
            "explicit",
            "stealth"
          ],
          "enumDescriptions": [
            "Show direct market labels such as Markets, FX, and Watchlist.",
            "Show generic labels that make the sidebar look less like a stock monitor."
          ],
          "markdownDescription": "Controls whether labels show direct market names (`explicit`) or generic operations-style names (`stealth`)."
        },
        "runtimeFeed.autoRefreshSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 3600,
          "markdownDescription": "Automatic refresh interval in seconds. `0` disables polling. Values above 3600 are capped by the extension."
        },
        "runtimeFeed.requestTimeoutMs": {
          "type": "number",
          "default": 10000,
          "minimum": 2000,
          "maximum": 60000,
          "markdownDescription": "HTTP timeout for upstream quote and news requests. Values above 60000 are capped by the extension."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^6.0.2"
  }
}
